# MongoDB
MONGO_ROOT_USER=flavora_admin
MONGO_ROOT_PASSWORD=StrongPassword123!@#

# এটা backend container-এর ভেতরে ব্যবহার হবে
DATABASE_URL="mongodb://flavora_admin:StrongPassword123!@#@mongo:27017/flavora_food?authSource=admin"

# Redis
REDIS_PASSWORD=RedisPass456!@#
REDIS_HOST=redis
REDIS_PORT=6379

# App
JWT_SECRET=your_64_char_minimum_jwt_secret_here_change_this_now
PORT=5000
NODE_ENV=production

# DigitalOcean Spaces (backup)
DO_SPACES_KEY=your_key
DO_SPACES_SECRET=your_secret
DO_SPACES_BUCKET=flavora-backups
DO_SPACES_REGION=sgp1